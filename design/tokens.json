{
  "name": "LivingBKK",
  "theme": "purple-white-minimal",
  "colors": {
    "primary": "#6B46C1",
    "primaryHover": "#5B3AA8",
    "primaryLight": "#EDE9FE",
    "primaryMuted": "#A78BFA",
    "background": "#FFFFFF",
    "backgroundAlt": "#FAFAFA",
    "surface": "#FFFFFF",
    "border": "#E5E7EB",
    "textPrimary": "#1F2937",
    "textSecondary": "#6B7280",
    "textOnPrimary": "#FFFFFF",
    "success": "#059669",
    "warning": "#D97706",
    "error": "#DC2626",
    "mapPinDefault": "#6B46C1",
    "mapPinCoAgent": "#4C1D95",
    "mapPinDemand": "#7C3AED"
  },
  "typography": {
    "fontFamily": "Inter, Noto Sans Thai, sans-serif",
    "scale": {
      "h1": "28px",
      "h2": "22px",
      "h3": "18px",
      "body": "16px",
      "caption": "13px",
      "label": "12px"
