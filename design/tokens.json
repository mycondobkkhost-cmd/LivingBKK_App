{
  "name": "PROPPITER",
  "theme": "proppiter-canva-v1",
  "description": "PROPPITER brand + Canva-style light UI (soft surfaces, pill controls, hero gradient)",
  "colors": {
    "primary": "#583AD6",
    "primaryHover": "#4A2FC4",
    "primaryLight": "#EDE9FE",
    "primaryMuted": "#9B6DFF",
    "accent": "#DB3D76",
    "background": "#F9F9FB",
    "backgroundAlt": "#FAF9FF",
    "surface": "#FFFFFF",
    "border": "#E8EAEF",
    "textPrimary": "#18104B",
    "textSecondary": "#6B7280",
    "textOnPrimary": "#FFFFFF",
    "navy": "#18104B",
    "success": "#10B981",
    "warning": "#F59E0B",
    "error": "#EF4444",
    "mapPinDefault": "#583AD6",
    "mapPinCoAgent": "#9B6DFF",
    "mapPinDemand": "#DB3D76",
    "headerGradientStart": "#ECF5FC",
    "headerGradientEnd": "#E3E3FD"
  },
  "typography": {
    "fontFamily": "Prompt, Noto Sans Thai, sans-serif",
    "scale": {
      "h1": "28px",
      "h2": "22px",
      "h3": "18px",
      "body": "16px",
      "caption": "13px",
      "label": "12px"
    }
  },
  "logo": {
    "taglineTh": "โพสต์ฟรี • ปิดดีลไว • ไม่ต้องหาลูกค้าเอง",
    "taglineEn": "Post for free • Close deals faster • No chasing clients yourself",
    "descriptorEn": "Real Estate Agent Platform",
    "fontFamily": "Prompt",
    "markGradient": ["#5634E3", "#9B6DFF", "#DB3D76"]
  },
  "radius": {
    "card": "16px",
    "button": "28px",
    "sheet": "24px",
    "chip": "999px",
    "search": "28px"
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px"
  },
  "shadow": {
    "card": "0 8px 20px rgba(88, 58, 214, 0.08)",
    "sheet": "0 -4px 24px rgba(0,0,0,0.10)"
  },
  "postListingMenu": {
    "createRoute": "/listing/create",
    "myListingsRoute": "/listings/mine",
    "perspectives": ["owner", "agent"],
    "showHomePromoForAll": true,
    "showHomeQuickPostCard": true,
    "profileItems": ["create", "mine"]
  },
  "demandBoardMenu": {
    "boardTabIndex": 2,
    "createRequirementRoute": "/requirements/create",
    "myRequirementsRoute": "/requirements/mine",
    "boardDetailPattern": "/board/:id",
    "boardOfferPattern": "/board/:id/offer",
    "requirementPerspectives": ["customer"],
    "offerPerspectives": ["owner", "agent"],
    "showHomeQuickRequirementCard": true,
    "showHomeQuickBoardCard": true,
    "showCustomerRequirementBanner": true
  }
}
