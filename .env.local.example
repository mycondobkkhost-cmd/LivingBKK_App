# คัดลอกเป็น .env.local แล้วใส่ค่าจริง (ไฟล์นี้ไม่ commit)
# cp .env.local.example .env.local

# Supabase → Dashboard → ปุ่ม Connect → แท็บ .env.local
SUPABASE_URL=https://auflqgqrmpbioflnhsrj.supabase.co
# วางค่าจาก NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY (ขึ้นต้น sb_publishable_)
# หรือ anon key แบบเก่า (ขึ้นต้น eyJ) ก็ได้
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx

# Google Cloud → API key (Maps JavaScript API + Places API)
GOOGLE_MAPS_API_KEY=AIzaSy...

# URL เว็บแอป (ใส่หลัง deploy Netlify) — ลิงก์แชร์ + นโยบาย/เงื่อนไขสาธารณะ
# ตัวอย่างชั่วคราว: https://quiet-kangaroo-ab6073.netlify.app
# หลังจดโดเมน Cloudflare: https://realxtateth.com — รัน ./scripts/setup-cloudflare-domain.sh
# DNS_PROVIDER=cloudflare
# สร้างที่ dash.cloudflare.com/profile/api-tokens → Edit zone DNS (realxtateth.com)
# CLOUDFLARE_API_TOKEN=
# CUSTOM_DOMAIN=realxtateth.com
# WEB_BASE_URL=https://realxtateth.com

# Netlify deploy อัตโนมัติ (./scripts/deploy-netlify.sh)
# สร้างที่ Netlify → User settings → Applications → Personal access tokens
# NETLIFY_AUTH_TOKEN=nfp_xxxxxxxx

# นำเข้า LI — ค้นหาชื่อโครงการ + ปักพิกัด Google Maps (ต้องใส่ทั้งแอปและ Edge)
# หลังใส่ key: supabase secrets set GOOGLE_MAPS_API_KEY=AIza... --project-ref YOUR_REF
# → Privacy: {WEB_BASE_URL}/legal/privacy.html  Terms: {WEB_BASE_URL}/legal/terms.html
WEB_BASE_URL=

# --- ก่อนส่ง App Store / Play Store (ฟรี — ไม่ต้องสมัครร้านก่อน) ---
# TRIAL_MODE=false
# ALLOW_PASSWORDLESS_LOGIN=false
# แล้วรัน: ./scripts/sync-env.sh && ./scripts/prepare-store-free.sh
# PRIVACY_POLICY_URL=   # override ถ้าโฮสต์คนละโดเมน
# TERMS_OF_SERVICE_URL=

# คีย์ลับฝั่งเซิร์ฟเวอร์ — Dashboard → Settings → API → service_role (secret)
# ใช้ตั้ง Edge Secrets (ดึงโครงการ / นำเข้า) — ห้ามใส่ในแอปมือถือ
# หลังใส่แล้วรัน: ./scripts/set-edge-secrets.sh
SUPABASE_SERVICE_ROLE_KEY=

# รหัส Database (PostgreSQL) — Dashboard → Settings → Database → Reset ถ้าจำไม่ได้
SUPABASE_DB_PASSWORD=
